<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        v1.5.3 → v2026 修复：
        1. 主题必须使用 AppCompat 系列（已与 AppCompatActivity 配套）
        2. forceDarkAllowed=false：禁止系统在暗色模式下把 Light 主题反色覆盖（ColorOS 16 兼容）
        3. windowSplashScreenBackground + windowSplashScreenAnimatedIcon：使用 Android 12+ 启动画面 API
        4. windowLayoutInDisplayCutoutMode=shortEdges：兼容打孔屏、刘海屏
        5. 2026 hotfix: windowBackground 使用 amoled_black 与 Compose 色值统一
        6. 2026 hotfix: colorPrimary/colorAccent 使用哈苏橙，与 Compose ColorOS16Colors 统一
        7. 2026 hotfix: 添加 Android 15+ 预测性返回相关配置
        8. 2026 hotfix: 必须设置 postSplashScreenTheme，否则启动画面结束后主题切换可能崩溃
    -->
    <style name="Theme.RapidRAW" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/amoled_black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>

        <!-- 哈苏橙品牌色（系统对话框/EditText 着色/分享 Intent 预览） -->
        <item name="colorPrimary">@color/hasselblad_orange</item>
        <item name="colorPrimaryDark">@color/hasselblad_orange_deep</item>
        <item name="colorAccent">@color/hasselblad_orange_bright</item>

        <!-- Android 12+ 启动画面（哈苏橙背景 + 白色图标） -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/hasselblad_orange</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenAnimationDuration" tools:targetApi="31">300</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">@color/hasselblad_orange</item>
        <!-- v2026.07 hotfix: 必须显式指定 postSplashScreenTheme，
             否则 Android 12+ 上启动画面结束后主题切换可能失败，
             ColorOS 16 / Android 16 (API 36) 上曾导致启动画面后窗口主题与 AppCompat 不匹配，
             AppCompatActivity 在 setContent 阶段抛 IllegalStateException。
             指向同一 Theme.RapidRAW，避免主题切换导致的视觉跳变。 -->
        <item name="android:postSplashScreenTheme" tools:targetApi="31">@style/Theme.RapidRAW</item>
        </style>
</resources>
