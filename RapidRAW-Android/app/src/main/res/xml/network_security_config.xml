<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 纯端侧应用：禁止明文流量 -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- v1.10.0 证书固定：对自有后端域名启用 SPKI Pin -->
