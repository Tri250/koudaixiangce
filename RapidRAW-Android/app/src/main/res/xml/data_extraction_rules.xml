<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
        <!-- Room 数据库文件 -->
        <exclude domain="database" path="rapidraw_db"/>
        <exclude domain="database" path="rapidraw_db-wal"/>
        <exclude domain="database" path="rapidraw_db-shm"/>
        <!-- Sidecar 文件 -->
        <exclude domain="file" path="sidecars/"/>
        <!-- Flow Mask PNG 文件 -->
        <exclude domain="file" path="flow_masks/"/>
        <!-- LUT 缓存 -->
        <exclude domain="file" path="lut_cache/"/>
        <!-- shared_prefs（可能包含用户偏好学习数据）-->
        <exclude domain="sharedpref" path="user_preference_learning.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
        <!-- Room 数据库文件 -->
        <exclude domain="database" path="rapidraw_db"/>
        <exclude domain="database" path="rapidraw_db-wal"/>
        <exclude domain="database" path="rapidraw_db-shm"/>
        <!-- Sidecar 文件 -->
        <exclude domain="file" path="sidecars/"/>
        <!-- Flow Mask PNG 文件 -->
        <exclude domain="file" path="flow_masks/"/>
        <!-- LUT 缓存 -->
        <exclude domain="file" path="lut_cache/"/>
        <!-- shared_prefs（可能包含用户偏好学习数据）-->
        <exclude domain="sharedpref" path="user_preference_learning.xml"/>
    </device-transfer>
</data-extraction-rules>
