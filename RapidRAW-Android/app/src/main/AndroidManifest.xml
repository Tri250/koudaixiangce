<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络：崩溃上报、云服务、诊断 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 存储：按 Android 版本精确声明 -->
    <!-- Android 13+ (API 33) 图片读取 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Android 14+ (API 34) 用户选择的部分媒体访问 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />
    <!-- Android 6~12 (API 23~32) 传统读取权限 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 4.4~9 (API 19~28) 写入权限；Android 10+ 使用 MediaStore/Scoped Storage -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- 通知：Android 13+ 必须动态申请 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 触觉反馈 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- 硬件能力声明 -->
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <!-- OpenGL ES 3.0 为必须，低版本设备将在安装阶段过滤 -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />
    <!-- Vulkan compute 用于 AI 加速（可选，ColorOS 16 设备有硬件加速） -->
    <uses-feature android:name="android.hardware.vulkan.compute" android:required="false" />
    <!-- Vulkan 1.3（Android 16 默认）支持 HDR 显示管线 -->
    <uses-feature android:name="android.hardware.vulkan.version" android:version="0x401003" android:required="false" />
    <!-- 触觉反馈硬件（可选，OPPO Find 等线性马达设备增强滑块交互） -->
    <uses-feature android:name="android.hardware.sensor.hifi_sensors" android:required="false" />

    <application
        android:name=".RapidRawApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RapidRAW"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        android:largeHeap="true"
        tools:targetApi="36">

        <!-- 2026 正式版本：APP 主题使用 3 色调暗色 (AMOLED 友好) -->
        <!-- Android 16 (API 36) 应用行为：edge-to-edge 已默认开启 -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|density|colorMode|fontWeightAdjustment|fontScale"
            android:windowSoftInputMode="adjustResize"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
                <data android:host="*" />
                <data android:mimeType="image/x-adobe-dng" />
                <data android:mimeType="image/x-canon-cr2" />
                <data android:mimeType="image/x-canon-cr3" />
                <data android:mimeType="image/x-nikon-nef" />
                <data android:mimeType="image/x-sony-arw" />
                <data android:mimeType="image/x-fuji-raf" />
                <data android:mimeType="image/x-olympus-orf" />
                <data android:mimeType="image/x-panasonic-rw2" />
                <data android:mimeType="image/x-pentax-pef" />
                <data android:mimeType="image/x-samsung-srw" />
            </intent-filter>
            <!-- ColorOS / OPPO Find 设备接收来自相册的"编辑图片"意图 -->
            <intent-filter>
                <action android:name="com.coloros.gallery3d.action.EDIT_IMAGE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
    </application>
</manifest>
