<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络：崩溃上报、云服务、诊断 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 存储：按 Android 版本精确声明 -->
    <!-- Android 13+ (API 33) 图片读取 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Android 14+ (API 34) 用户选择的部分媒体访问 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />
    <!-- Android 6~12 (API 23~32) 传统读取权限 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- v1.5.5 hotfix: 代码中请求了 POST_NOTIFICATIONS 但 Manifest 未声明，
         导致 Android 13+ 上通知权限永远无法授予，WorkManager 前台任务可能因
         缺少通知而抛 RemoteServiceException 闪退。 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- v1.10.2: 前台服务权限（Android 9+ 导出队列需要） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROCESSING" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- v1.10.2: 电池优化豁免请求（长时间导出避免被系统杀死） -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 硬件能力声明 -->
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <!-- OpenGL ES 3.0（可选：无 GLES 3.0 时回退 CPU 管线） -->
    <uses-feature android:glEsVersion="0x00030000" android:required="false" />
    <!-- 触觉反馈硬件（可选，OPPO / Find 系列线性马达设备增强滑块交互） -->
    <uses-feature android:name="android.hardware.vibrator" android:required="false" />

    <!-- TensorFlow Lite 等依赖可能合并 READ_PHONE_STATE，但本应用无需该权限；
         显式移除以避免隐私合规与 Play 商店审核警告。 -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" tools:node="remove" />

    <application
        android:name=".RapidRawApp"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RapidRAW"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:enableOnBackInvokedCallback="true"
        android:largeHeap="true"
        android:appCategory="image"
        android:hasFragileUserData="false"
        android:localeConfig="@xml/locale_config"
        tools:targetApi="36">

        <!-- 2026 正式版本：APP 主题使用 3 色调暗色 (AMOLED 友好) -->
        <!-- Android 16 (API 36) 应用行为：edge-to-edge 已默认开启 -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|density|colorMode|fontWeightAdjustment|fontScale"
            android:windowSoftInputMode="adjustResize"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="false">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
                <data android:host="*" />
                <data android:mimeType="image/x-adobe-dng" />
                <data android:mimeType="image/x-canon-cr2" />
                <data android:mimeType="image/x-canon-cr3" />
                <data android:mimeType="image/x-nikon-nef" />
                <data android:mimeType="image/x-sony-arw" />
                <data android:mimeType="image/x-fuji-raf" />
                <data android:mimeType="image/x-olympus-orf" />
                <data android:mimeType="image/x-panasonic-rw2" />
                <data android:mimeType="image/x-pentax-pef" />
                <data android:mimeType="image/x-samsung-srw" />
            </intent-filter>
            <!-- ColorOS / OPPO Find 设备接收来自相册的"编辑图片"意图 -->
            <intent-filter>
                <action android:name="com.coloros.gallery3d.action.EDIT_IMAGE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- 深层链接：支持 rapidraw://editor/{path} 与 rapidraw://editor_uri/{uri} -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="rapidraw" />
            </intent-filter>
            <!-- v1.10.3: App Shortcuts 元数据 -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- FileProvider: 为导出完成的图片提供临时 URI，支持从导出队列打开/分享 -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
