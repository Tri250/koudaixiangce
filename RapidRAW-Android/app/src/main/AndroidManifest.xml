<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 网络：崩溃上报、云服务、诊断 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 存储：按 Android 版本精确声明 -->
    <!-- Android 13+ (API 33) 图片读取 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- Android 14+ (API 34) 用户选择的部分媒体访问 -->
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />
    <!-- Android 6~12 (API 23~32) 传统读取权限 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 4.4~9 (API 19~28) 写入权限；Android 10+ 使用 MediaStore/Scoped Storage -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- 通知：Android 13+ 必须动态申请 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 触觉反馈 -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- 硬件能力声明 -->
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <!-- OpenGL ES 3.0 为必须，低版本设备将在安装阶段过滤 -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />

    <application
        android:name=".RapidRawApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RapidRAW"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        android:largeHeap="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|density"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" />
                <data android:host="*" />
                <data android:mimeType="image/x-adobe-dng" />
                <data android:mimeType="image/x-canon-cr2" />
                <data android:mimeType="image/x-canon-cr3" />
                <data android:mimeType="image/x-nikon-nef" />
                <data android:mimeType="image/x-sony-arw" />
                <data android:mimeType="image/x-fuji-raf" />
                <data android:mimeType="image/x-olympus-orf" />
                <data android:mimeType="image/x-panasonic-rw2" />
                <data android:mimeType="image/x-pentax-pef" />
                <data android:mimeType="image/x-samsung-srw" />
            </intent-filter>
        </activity>
    </application>
</manifest>
